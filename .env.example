# ── Database ──────────────────────────────────────────────
DATABASE_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-this-development-secret-to-a-secure-32-character-value
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14

# ── Frontend ──────────────────────────────────────────────
# Used during local development only (Docker build sets this automatically)
VITE_API_BASE_URL=http://localhost:8080/api/v1
